    {
        "id": "332e710897eddc95",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "7708af146d269f69",
        "name": "progress_follow",
        "func": "if(msg.payload == 0 && flow.get(\"machine_enable\") == 0) {\n    let out1 = { payload: 0 };\n    let out2 = { payload: 0 };\n    let out3 = { payload: 0 + \"%\" };\n    let out4 = { payload: \"--:--:--\" };\n    return[out1, out2, out3, out4];\n}\n\n// Adatok lekérése a memóriából\nlet target = flow.get(\"target_quantity\") || 0;\nlet current = flow.get(\"product_counter\") || 0;\n\nlet times = flow.get(\"production_timestamps\") || [];\n\nif (current === 1) {\n    times = [];\n}\n\ntimes.push(Date.now());\nflow.set(\"production_timestamps\", times);\n\n// 1. kimenet: CÉL (egyszerű szám)\nlet out1 = { payload: target };\n\n// 2. kimenet: KÉSZ (aktuális darabszám)\nlet out2 = { payload: current };\n                                                                                    \n// 3. kimenet: HALADÁS (százalékos formátum)\nlet percent = (target > 0) ? Math.round((current / target) * 100) : 0;\nlet out3 = { payload: percent + \"%\" };\n\n// 4. kimenet: HÁTRALÉVŐ IDŐ (Predikció: óó:pp:mm)\nlet timeStr = \"--:--:--\";\n\n// Csak akkor számolunk, ha már van kész termék és fut a gép\nif (times.length > 1 && target > current) {\n    let timeSoFarMs = times[times.length - 1] - times[0]; // Ennyi ideje megy a gyártás összesen\n\n    let produced = times.length;\n\n    let ratioOfGoalAndProduced = target / produced;\n\n    let timeForAllMs = timeSoFarMs * ratioOfGoalAndProduced;\n\n    let predictedRemainingMs = timeForAllMs - timeSoFarMs;\n\n    flow.set(\"remainingTimeMs\", predictedRemainingMs);\n\n    // Milliszekundum átalakítása olvasható formátumba\n    let totalSeconds = Math.floor(predictedRemainingMs / 1000);\n    let hours = Math.floor(totalSeconds / 3600);\n    let minutes = Math.floor((totalSeconds % 3600) / 60);\n    let seconds = totalSeconds % 60;\n\n    // Szöveges formázás: 00:00:00\n    timeStr = [hours, minutes, seconds]\n        .map(v => v < 10 ? \"0\" + v : v)\n        .join(\":\");\n} else if(target > 0 && current >= target){\n    timeStr = \"00:00:00\";\n    flow.set(\"remainingTimeMs\", 0);\n    flow.set(\"production_timestamps\", []);\n}\n\nlet out4 = { payload: timeStr };\n\nreturn [out1, out2, out3, out4];",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1180,
