    {
        "id": "bd862626b4e2b2a1",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "48d2f444e75316da",
        "name": "jogosultság text",
        "func": "if (flow.get(\"cardOK\") == 1)\n{\n    msg.payload=\"Jogosult\";\n    return msg;\n}\nelse if (flow.get(\"cardOK\") == 0)\n{\n    msg.payload = \"Nem jogosult\";\n    return msg;\n}\nelse\n{\n    msg.payload =\" \";\n    return msg;\n}\nreturn;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 760,
        "y": 1480,
        "wires": [
            [
                "1fdf35b03b738446",
                "ced21323586b7310"
            ]
        ]
    },
    {
        "id": "fcb9d7e622fa4947",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "48d2f444e75316da",
        "name": "timestamp format",
        "func": "// Eredeti string\nlet inputString = msg.payload.dateTime;\n\n// Eredmény string inicializálása üres stringként\nlet resultString = \"\";\n\n// Végigmegyünk a stringen karakterenként\nfor (let i = 0; i < inputString.length; i++) {\n    // Ellenőrizzük, hogy az aktuális karakter \"T\"-e\n    if (inputString[i] === 'T') {\n        // Ha \"T\", akkor hozzáadunk egy szóközt az eredmény stringhez\n        resultString += ' ';\n    } else {\n        // Ha nem \"T\", akkor hozzáadjuk az eredeti karaktert az eredmény stringhez\n        resultString += inputString[i];\n    }\n}\nmsg.payload = resultString;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 750,
        "y": 1440,
        "wires": [
            [
                "e3da25261b245079"
            ]
        ]
    },
    {
        "id": "513ac12204be3463",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "48d2f444e75316da",
        "name": "-",
        "func": "if(msg.payload == 1 || msg.payload == 0)\n{msg.payload = \" \" ;\nreturn msg;}\nreturn;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 790,
        "y": 1400,
        "wires": [
            [
                "39dc6367b7487681",
                "e3da25261b245079",
                "1fdf35b03b738446"
            ]
        ]
    },
    {
        "id": "fb32392d39bdcf03",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "7708af146d269f69",
        "name": "product counter",
        "func": "let target = flow.get(\"target_quantity\") || 0;\nlet isScrap = flow.get(\"selejt_state\") || 0;\n\nif (msg.payload === 1 && target > 0) {\n    let current = flow.get(\"product_counter\") || 0;\n    current++;\n    flow.set(\"product_counter\", current);\n\n    if (isScrap == 0){\n        let good = flow.get(\"good_counter\") || 0;\n        good++;\n        flow.set(\"good_counter\", good);\n    }\n\n    flow.set(\"selejt_state\", 0);\n\n    // Ha elérte a célmennyiséget → leállítás\n    if (target > 0 && current >= target) {\n        flow.set(\"machine_enable\", 0);\n        flow.set(\"lock_state\", 0);\n        msg.payload = 0;\n        return msg;\n    }\n\n    // Normál működés – csak a darabszám küldése tovább\n    msg.payload = current;\n    return msg;\n}\n\nreturn;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 740,
        "y": 580,
        "wires": [
            [
                "ad7ec29018d37c14",
                "332e710897eddc95",
                "242d501a3f65b68e",
                "59b29317076fc52e"
            ]
        ]
    },
    {
        "id": "53b7528a3fb118b1",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "7708af146d269f69",
        "name": "all_wait_counter",
        "func": "\n/*\nvar temp = context.get(\"count\") || 0;\ntemp++ ;\nmsg.payload = temp;\ncontext.set(\"count\",temp);\nreturn msg;\n*/\nvar temp;\n\nif (Array.isArray(msg.payload) && msg.payload.length === 0) {\ncontext.set(\"count\",0);\ntemp = 0;\n}\nelse\n{\ntemp = context.get(\"count\") || 0;\ntemp++ ;\nmsg.payload = temp;\ncontext.set(\"count\",temp);\nreturn msg;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 700,
        "y": 660,
        "wires": [
            [
                "964ed374fef0a265"
            ]
        ]
    },
