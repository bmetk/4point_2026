    {
        "id": "edc96016553c87e0",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "57212797686269db",
        "name": "selejt_to_pi",
        "func": "// Selejt állapot mentése\nlet newState = msg.payload;\nlet prevState = flow.get(\"selejt_state\") || 0;\n\nflow.set(\"selejt_state\", newState);\n\n// Csak RISING EDGE-nél számolunk (0 → 1 átmenet)\nif (newState === 1 && prevState === 0) {\n    // Selejt számláló növelése\n    let scrap = flow.get(\"scrap_counter\") || 0;\n    scrap++;\n    flow.set(\"scrap_counter\", scrap);\n    \n    let good = flow.get(\"good_counter\");\n    if(good > 0) good--;\n    flow.set(\"good_counter\", good)\n}\n\n// NE állítsuk le itt a gépet - a cél ellenőrzés a product counter-nél történjen\nmsg.payload = newState;\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 900,
        "wires": [
            [
                "c3eb94595174c91d",
                "50fd6c72efbcc76a",
                "12be046e7a58dd3b"
            ]
        ]
