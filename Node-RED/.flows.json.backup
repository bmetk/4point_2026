    {
        "id": "50fd6c72efbcc76a",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "57212797686269db",
        "name": "R_trig (intput have to be true or false)",
        "func": "var lastValue = context.get('lastValue') || false;\n\nif (msg.payload && lastValue == false) {\n    node.send(msg);\n    node.status({ fill: \"green\", shape: \"dot\", text: \"triggered\" });\n}\n\ncontext.set(\"lastValue\", msg.payload)\n\nreturn;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
