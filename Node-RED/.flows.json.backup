        "group": "1245d920678a7c21",
        "name": "Target Quantity format",
        "order": 22,
        "width": 0,
        "height": 0,
        "format": "<div ng-bind-html=\"msg.payload\"></div>\n<style>\n    .keret {\n        border: 2px solid #0094ce; /* A gombjaid kék színe */\n        border-radius: 6px;\n    }\n\n    .keret md-input-container .md-input {\n    border-bottom-style: none;\n    }\n    \n    .keret md-input-container.md-input-focused .md-input {\n    border-bottom-style: none;\n    }\n    \n    .keret md-input-container .md-errors-spacer {\n    display: none;\n    min-height: 0;\n    }\n    \n    .keret md-input-container .md-input-messages-animation {\n    display: none;\n    }\n    </style>\n</style>",
        "storeOutMessages": true,
        "fwdInMessages": true,
