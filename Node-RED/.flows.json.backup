    {
        "id": "ba3339a68dc7369e",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "7708af146d269f69",
        "name": "insert data to chart",
        "func": "var name = \"Megfelelő\"; // Ez jelenik meg a tooltipben\nvar timestamp = new Date(Date.now());\nvar cleantimestamp = timestamp.toISOString().slice(11, -5).replace(\"T\", \" \"); // Óra : perc : másodperc formátum\n\nmsg = {\n    topic: \"Megfelelő\",\n    label: cleantimestamp,\n    series: name,\n    payload: msg.payload,\n    color_msg: '#0000FF' // Kék szín\n};\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 990,
        "y": 460,
