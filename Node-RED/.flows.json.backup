    {
        "id": "c52b7923a050fa2c",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "7708af146d269f69",
        "name": "Timer",
        "func": "let remainingMs = flow.get(\"remainingTimeMs\") || 0;\nlet isRunning = flow.get(\"lock_state\") || 0; // Csak ha megy a gép\n\nif (isRunning === 1 && remainingMs > 0) {\n    // Csökkentjük 1 másodperccel (1000 ms)\n    remainingMs -= 1000;\n    if (remainingMs < 0) remainingMs = 0;\n    \n    // Elmentjük a csökkentett értéket\n    flow.set(\"remainingTimeMs\", remainingMs);\n\n    // Formázás óó:pp:mm-re\n    let totalSeconds = Math.floor(remainingMs / 1000);\n    let hours = Math.floor(totalSeconds / 3600);\n    let minutes = Math.floor((totalSeconds % 3600) / 60);\n    let seconds = totalSeconds % 60;\n\n    let timeStr = [hours, minutes, seconds]\n        .map(v => v < 10 ? \"0\" + v : v)\n        .join(\":\");\n\n    msg.payload = timeStr;\n    return msg;\n}\nmsg.payload = \"--:--:--\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1210,
        "y": 700,
        "wires": [
            [
                "555273a84fd3d029"
            ]
        ]
    },
