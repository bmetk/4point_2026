        "name": "reseter",
        "func": "if(flow.get(\"lock_state\") == 0){\n    flow.set(\"lock_state\",0);\n    flow.set(\"selejt_state\", 0);\n    flow.set(\"selejt_from_pi_state\", 1);\n    flow.set('previousTimestamp', 0);\n    flow.set(\"product_counter\", 0);\n    flow.set(\"good_counter\", 0);\n    flow.set(\"scrap_counter\", 0);\n    flow.set(\"all_wait\", 1);\n    flow.set(\"target_quantity\", 0);\n\n    msg.payload = [];\n    msg.topic = \"reset\";\n    return msg;\n}\n\nreturn null;",
        "outputs": 1,
