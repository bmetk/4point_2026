    {
        "id": "de131aef6f95edce",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "7708af146d269f69",
        "name": "Időkülönbség kiszámítása",
        "func": "// A function node beállítása az idő különbség kiszámítására\nlet currentTimestamp = Date.now() / 1000; // Jelenlegi idő másodpercben\n//let previousTimestamp = context.get('previousTimestamp') || 0; // Előző időpont\nlet previousTimestamp = flow.get('previousTimestamp') || 0; // Előző időpont\n\nlet timeDifference = 0;\nif (previousTimestamp !== 0) {\n    timeDifference = currentTimestamp - previousTimestamp-2.4;\n}\n\n// Az aktuális időpont elmentése a következő üzenethez\nflow.set('previousTimestamp', currentTimestamp);\n\n// Az üzenetbe beírjuk az eltelt időt másodpercben\nmsg.payload = timeDifference;\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 770,
        "y": 460,
        "wires": [
            [
                "ba3339a68dc7369e",
                "649f0fc1b68ec55a"
            ]
        ]
    },
    {
        "id": "eeceb649a6d02305",
        "type": "function",
        "z": "b306b2a9ca758148",
        "d": true,
        "name": "Gauss Eloszlás",
        "func": "function gaussianRandom(mean, stdev) {\n    let u1 = 0, u2 = 0;\n    // Convert [0,1) to (0,1)\n    while (u1 === 0) u1 = Math.random();\n    while (u2 === 0) u2 = Math.random();\n    let z0 = Math.sqrt(-2.0 * Math.log(u1)) * Math.cos(2.0 * Math.PI * u2);\n    // Adjust for mean and standard deviation\n    return z0 * stdev + mean;\n}\n\nlet mean = 3.5;  // középérték\nlet stdev = 1.5;  // szórás\n\nfunction sendRandom() {\n    // Generáljuk a Gauss eloszlás szerinti időközt\n    let interval = gaussianRandom(mean, stdev) * 1000;  // milliszekundumra konvertálás\n\n    // Korlátozzuk az időközt 0 és 7000 ms közé\n    interval = Math.max(0, Math.min(7000, interval));\n\n    // Küldjünk ki egy '1' üzenetet és tároljuk az időbélyeget\n    let timestamp = Date.now();\n    node.send({ payload: 1, timestamp: timestamp });\n\n    // Várjunk az interval ideig, majd küldjünk '0' üzenetet és indítsuk újra a folyamatot\n    setTimeout(() => {\n        node.send({ payload: 0 });\n        setTimeout(sendRandom, 1000); // 1 másodperc múlva újraindítjuk a folyamatot\n    }, interval);\n}\n\n// Elindítjuk az első hívást\nsendRandom();\n\n// Mivel az üzenetküldést a setTimeout kezeli, itt nem küldünk vissza üzenetet\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 4280,
        "wires": [
            [
                "5f89242b5b51814a"
            ]
        ]
    },
