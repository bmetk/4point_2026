    {
        "id": "1bf2f7b21f7bd062",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "e120fffe66c64f5f",
        "name": "target_set",
        "func": "let isLocked = Number(flow.get(\"lock_state\")) || 0;\n\nif (isLocked === 1) {\n    node.status({ fill: \"red\", shape: \"ring\", text: \"Módosítás tiltva: A gép aktív!\" });\n    return null;\n}\n\nlet newTarget = parseInt(msg.payload);\n\n// Ha az input nem szám (pl. üres string vagy null), ne csináljon semmit\nif (isNaN(newTarget)) {\n    node.status({ fill: \"yellow\", shape: \"ring\", text: \"Várakozás érvényes számra...\" });\n    return null;\n}\n\nif(newTarget >= 0){\n    flow.set(\"target_quantity\", newTarget);\n    node.status({ fill: \"green\", shape: \"dot\", text: \"Cél rögzítve: \" + newTarget });\n    msg.payload = newTarget;\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
        "y": 1620,
