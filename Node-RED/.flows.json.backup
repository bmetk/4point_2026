        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "57212797686269db",
        "name": "color and label",
        "func": "if(msg.payload == 1 && flow.get(\"target_quantity\") > 0)\n{\n    msg.payload = {\"color\": null,\"Label\": null};\n    msg.payload.color = \"rgb(143,0,0)\";\n    msg.payload.Label = \"Gyártás leállítása\";\n}\nelse\n{\n    flow.set(\"target_reached\", 0);\n    msg.payload = {\"color\": null,\"Label\": null};\n    msg.payload.color = \"rgb(5,152,98)\";\n    msg.payload.Label = \"Gyártás indítása\";\n}\nreturn msg;",
        "outputs": 1,
