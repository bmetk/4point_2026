            [
                "5f3f795c7a338692"
            ]
        ]
    },
    {
        "id": "f546817b5cbabddc",
        "type": "ui_template",
        "z": "b306b2a9ca758148",
        "g": "e120fffe66c64f5f",
        "group": "9cb1920c660ae580",
        "name": "Elkészült/Selejt",
        "order": 13,
        "width": 9,
        "height": 4,
        "format": "<script src=\"https://cdn.jsdelivr.net/npm/apexcharts\"></script>\n\n<style>\n    .nr-dashboard-template {\n        overflow: hidden;\n        padding: 0;\n    }\n\n    /* ===== SAJÁT SZÍNEK (mint a gomboknál) ===== */\n    :root {\n        --good-color: #00E396;\n        --scrap-color: #FF0000;\n    }\n\n    #semidonut_container {\n        display: flex;\n        justify-content: center;\n        align-items: center;\n        width: 100%;\n        height: 500px;\n    }\n\n    #semidonut_chart {\n        width: 320px;\n        height: 280px;\n    }\n\n    /* ===== KÖZÉPSŐ SZÖVEG ===== */\n    #center_text {\n        position: absolute;\n        top: 48%;\n        left: 50%;\n        transform: translate(-50%, -50%);\n        text-align: center;\n        pointer-events: none;\n        line-height: 1.5;\n        z-index: 10;\n    }\n\n    #good_val {\n        color: var(--good-color);\n        font-size: 15px;\n        font-weight: 600;\n    }\n\n    #scrap_val {\n        color: var(--scrap-color);\n        font-size: 15px;\n        font-weight: 600;\n    }\n\n    #ratio_val {\n        color: #2dc4cb;\n        font-size: 15px;\n        margin-top: 4px;\n    }\n\n    /* ===== stroke fix ===== */\n    .apexcharts-canvas .apexcharts-pie-series path {\n        stroke: #FFF !important;\n        stroke-width: 2px !important;\n    }\n</style>\n\n<div id=\"semidonut_container\">\n    <div style=\"position: relative;\">\n        <div id=\"center_text\">\n            <div id=\"good_val\">Jó: 0</div>\n            <div id=\"scrap_val\">Selejt: 0</div>\n            <div id=\"ratio_val\">Hibaarány: 0%</div>\n        </div>\n\n        <h3 style=\"text-align: center; margin: 5px 0 8px 0; color: #ddd;\">\n            Elkészült / Selejt\n        </h3>\n\n        <div id=\"semidonut_chart\"></div>\n    </div>\n</div>\n\n<script>\n    (function(scope) {\n        let chart = null;\n\n        const getColors = () => {\n            const style = getComputedStyle(document.documentElement);\n            return [\n                style.getPropertyValue('--good-color').trim(),\n                style.getPropertyValue('--scrap-color').trim()\n            ];\n        };\n\n        const options = {\n            chart: {\n                type: 'donut',\n                height: 280,\n                sparkline: { enabled: true },\n                animations: { enabled: false }\n            },\n            series: [1],\n            labels: [''],\n            colors: ['transparent'],\n            stroke: {\n                show: true,\n                width: 2,\n                colors: ['#FFF']\n            },\n            fill: { opacity: 0 },\n            plotOptions: {\n                pie: {\n                    startAngle: -90,\n                    endAngle: 90,\n                    donut: {\n                        size: '75%',\n                        labels: { show: false }\n                    }\n                }\n            },\n            legend: {\n                show: true,\n                position: 'bottom'\n            }\n        };\n\n        // Init chart\n        setTimeout(() => {\n            const el = document.getElementById(\"semidonut_chart\");\n            if (el && !chart) {\n                chart = new ApexCharts(el, options);\n                chart.render();\n            }\n        }, 50);\n\n        // DOM Elements\n        const goodEl = document.getElementById(\"good_val\");\n        const scrapEl = document.getElementById(\"scrap_val\");\n        const ratioEl = document.getElementById(\"ratio_val\");\n\n        // Watch for incoming Node-RED messages\n        scope.$watch('msg', function(msg) {\n            if (!msg) return;\n\n            // ===== RESET LOGIKA =====\n            if (msg.topic === \"reset\" || (Array.isArray(msg.payload) && msg.payload.length === 0)) {\n                goodEl.innerHTML = `Jó: 0`;\n                scrapEl.innerHTML = `Selejt: 0`;\n                ratioEl.innerHTML = `Hibaarány: 0%`;\n\n                if (chart) {\n                    chart.updateOptions({\n                        labels: [''],\n                        colors: ['transparent'],\n                        fill: { opacity: 0 }\n                    }, false, false);\n                    chart.updateSeries([1], false);\n                }\n                return;\n            }\n\n            // ===== ADATFELDOLGOZÁS ÉS MEGJELENÍTÉS =====\n            if (!msg.payload || typeof msg.payload !== \"object\") return;\n\n            const good = Number(msg.payload.good) || 0;\n            const scrap = Number(msg.payload.scrap) || 0;\n            const total = good + scrap;\n\n            // Szöveges értékek frissítése\n            goodEl.innerHTML = `Jó: ${good}`;\n            scrapEl.innerHTML = `Selejt: ${scrap}`;\n\n            const ratio = total > 0 ? ((scrap / total) * 100).toFixed(1) : 0;\n            ratioEl.innerHTML = `Hibaarány: ${ratio}%`;\n\n            if (!chart) return;\n\n            // Grafikon frissítése\n            if (total === 0) {\n                chart.updateOptions({\n                    labels: [''],\n                    colors: ['transparent'],\n                    fill: { opacity: 0 }\n                }, false, false);\n                chart.updateSeries([1], false);\n            } else {\n                const [goodColor, scrapColor] = getColors();\n\n                chart.updateOptions({\n                    labels: ['Elkészült', 'Selejt'],\n                    colors: [goodColor, scrapColor],\n                    fill: { opacity: 1 }\n                }, false, false);\n\n                chart.updateSeries([good, scrap], true);\n\n                // ===== HARD SVG FIX (Kényszerített színezés Node-RED ellen) =====\n                setTimeout(() => {\n                    const paths = document.querySelectorAll('#semidonut_chart svg path');\n                    if (paths.length >= 2) {\n                        paths[0].style.fill = goodColor;\n                        paths[1].style.fill = scrapColor;\n                    }\n                }, 20);\n            }\n        });\n    })(scope);\n</script>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 840,
