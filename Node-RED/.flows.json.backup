    {
        "id": "d0b76dff6ead9a73",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "48d2f444e75316da",
        "name": "autentikáció",
        "func": "if(flow.get('login_state')==1 && flow.get(\"somebodyIn\")==0)\n{\n    if(flow.get(\"cardOK\") == 1)\n    {\n        flow.set(\"machine_enable\",1);\n    }\n    else if(flow.get(\"cardOK\")  == 0 || msg.payload.cardOK == 0)\n    {\n        flow.set(\"machine_enable\",0);\n    }\n    flow.set(\"somebodyIn\",1);\n    return msg;\n}\nelse if(flow.get('login_state')==0)\n{\n    flow.set(\"machine_enable\",0);\n    msg.payload={};\n    return msg; \n}\nreturn;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 510,
        "y": 1400,
        "wires": [
            [
                "39dc6367b7487681",
                "fcb9d7e622fa4947"
            ]
        ]
    },
    {
        "id": "432a04f2e7904499",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "48d2f444e75316da",
        "name": "login txt",
        "func": "if(msg.payload == 1)\n{\n    msg.payload=\"Olvassa le a belépőkártyát!\"\n    return msg;\n}\nelse if(msg.payload == 0)\n{\n    msg.payload=\"Sikeresen kilépett.\"\n    return msg;\n}\nreturn;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 800,
        "y": 1320,
