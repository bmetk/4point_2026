    {
        "id": "3f0819d03e8d7923",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "e120fffe66c64f5f",
        "name": "data_for_pie_chart",
        "func": "let all = flow.get(\"product_counter\") || 0;\nlet scrap = flow.get(\"scrap_counter\") || 0;\nlet good = flow.get(\"good_counter\") || 0;\n\n// Ha reset jön a topicban\nif (msg.topic === \"reset\") {\n    msg.payload = { good: 0, scrap: 0 };\n    msg.topic = \"reset\";\n    return msg;\n}\n\nif(good + scrap == all){\n    msg.payload = {\n        good: parseInt(good),\n        scrap: parseInt(scrap)\n    };\n}    \nreturn msg;",
