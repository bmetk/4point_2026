    {
        "id": "51da38d3300ceee0",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "48d2f444e75316da",
        "name": "Login_controll_by_Button",
        "func": "if(msg.payload == 1)\n{\n    flow.set('login_state',1);\n    msg.topic = \"on\";\n    msg.payload = true;\n    return msg;\n}\nelse if(msg.payload == 0)\n{\n    flow.set('login_state',0);\n    flow.set(\"machine_enable\",0);\n    flow.set(\"somebodyIn\",0);\n    return msg;\n}\nreturn;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 470,
        "y": 1340,
