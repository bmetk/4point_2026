                "b94bc6b8bad8546e"
            ]
        ]
    },
    {
        "id": "98d9b8cbba23164e",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "48d2f444e75316da",
        "name": "RFID_cardOK",
        "func": "if(msg.payload == 0)\n{\n    flow.set(\"cardOK\",1);\n    flow.set(\"machine_enable\",1)\n    msg.payload = flow.get(\"cardOK\");\n    return msg;\n}\nelse if(msg.payload == 1)\n{\n    flow.set(\"cardOK\",0);\n    flow.set(\"machine_enable\",0)\n    msg.payload = flow.get(\"cardOK\");\n    return msg;\n}\nreturn;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1000,
        "y": 1240,
        "wires": [
            [
                "5ef26da0e4e3c4e5"
            ]
        ]
    },
    {
        "id": "39d16f9d33a49fdb",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "48d2f444e75316da",
        "name": "F_trig (intput have to be true or false)",
        "func": "var lastValue = context.get('lastValue') || 1;\n\nif(msg.payload == 0 && lastValue){\n    node.status({ fill: \"green\", shape: \"dot\", text: \"triggered\" });\n    node.send(msg);\n} else {\n    node.status({ fill: \"grey\", shape: \"dot\", text: \"triggered\" });\n}\n\ncontext.set(\"lastValue\",msg.payload)\n\nreturn; ",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 690,
        "y": 1240,
        "wires": [
