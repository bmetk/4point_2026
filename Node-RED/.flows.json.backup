                "513ac12204be3463"
            ]
        ]
    },
    {
        "id": "060b0a99101bc15b",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "48d2f444e75316da",
        "name": "color and label",
        "func": "if(msg.payload == 1)\n{\n    msg.payload = {\"color\": null,\"Label\": null};\n    msg.payload.color = \"rgb(195,215,19)\";\n    msg.payload.Label = \"Kijelentkezés\";\n}\nelse\n{\n    msg.payload = {\"color\": null,\"Label\": null};\n    msg.payload.color = \"rgb(9,116,121)\";\n    msg.payload.Label = \"Bejelentkezés\";\n}\nreturn msg;",
        "outputs": 1,
