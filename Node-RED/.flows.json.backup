    {
        "id": "4367cb220ca2d957",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "57212797686269db",
        "name": "Időkülönbség kiszámítása",
        "func": "// A function node beállítása az idő különbség kiszámítására\nlet currentTimestamp = Date.now() / 1000; // Jelenlegi idő másodpercben\n//let previousTimestamp = context.get('previousTimestamp') || 0; // Előző időpont\nlet previousTimestamp = flow.get('previousTimestamp') || 0; // Előző időpont\n\nlet timeDifference = 0;\nif (previousTimestamp !== 0) {\n    timeDifference = currentTimestamp - previousTimestamp-2.4;\n}\n\n// Az aktuális időpont elmentése a következő üzenethez\nflow.set('previousTimestamp', currentTimestamp);\n\n// Az üzenetbe beírjuk az eltelt időt másodpercben\nmsg.payload = timeDifference;\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1090,
        "y": 840,
        "wires": [
            [
                "290d06b34298f1c4"
            ]
        ]
    },
    {
        "id": "290d06b34298f1c4",
        "type": "function",
        "z": "b306b2a9ca758148",
        "g": "57212797686269db",
        "name": "insert data to chart",
        "func": "var name = \"Selejt\"; // Ez jelenik meg a tooltipben\nvar timestamp = new Date(Date.now());\nvar cleantimestamp = timestamp.toISOString().slice(11, -5).replace(\"T\", \" \"); // Óra : perc : másodperc formátum\n\nmsg = {\n    topic: \"Selejt\",\n    label: cleantimestamp,\n    series: name,\n    payload: msg.payload,\n    color_msg: '#FFA500' // Narancssárga szín\n};\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1310,
        "y": 840,
        "wires": [
            [
                "78de76932c6617be"
            ]
        ]
    },
    {
        "id": "ca528371f5b21479",
        "type": "mqtt in",
        "z": "b306b2a9ca758148",
        "g": "48d2f444e75316da",
        "name": "Pi_RFID_input",
        "topic": "ionoPi/Di1",
        "qos": "2",
        "datatype": "auto-detect",
        "broker": "458249f8ed2df35f",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 160,
        "y": 1240,
        "wires": [
