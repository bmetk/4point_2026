    {
        "id": "c8317a5089d4e8b8",
        "type": "mqtt in",
        "z": "b306b2a9ca758148",
        "g": "57212797686269db",
        "name": "selejt_to_pi",
        "topic": "ionoPi/Di5",
        "qos": "2",
        "datatype": "auto-detect",
        "broker": "458249f8ed2df35f",
