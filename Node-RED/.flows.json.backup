    {
        "id": "0119478042d2649b",
        "type": "ui_template",
        "z": "b306b2a9ca758148",
        "g": "7708af146d269f69",
        "group": "9cb1920c660ae580",
        "name": "Gyártási idő",
        "order": 18,
        "width": 25,
        "height": 8,
        "format": "<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/apexcharts@latest/dist/apexcharts.css\" />\n<script src=\"https://cdn.jsdelivr.net/npm/apexcharts@latest\"></script>\n\n<style>\n    .nr-dashboard-template {\n        padding: 10;\n        margin: 0;\n        height: 100%;\n        overflow: hidden;\n    }\n\n    #chart {\n        max-width: 100%;\n        width: 100%;\n        height: 380px;\n        margin: 0 auto;\n    }\n</style>\n\n<h2 style=\"color: white; text-align: center;\"> Ütemidő és Minőség </h2>\n<div id=\"chart\"></div>\n\n<script>\n    (function(scope) {\n        // Initialize chart\n        const chartOptions = {\n            chart: {\n                type: 'bar',\n                height: 380\n            },\n            series: [{\n                name: \"Adatok\",\n                data: []\n            }],\n            xaxis: {\n                categories: [],\n                labels: {\n                    style: {\n                        colors: '#fff',\n                        fontSize: '14px',\n                        fontWeight: 600\n                    }\n                }\n            },\n            yaxis: {\n                min: 0,\n                max: 10,\n                labels: {\n                    formatter: function(val) {\n                        return val.toFixed(4);\n                    },\n                    style: {\n                        colors: '#fff',\n                        fontSize: '14px',\n                        fontWeight: 600\n                    }\n                }\n            },\n            annotations: {\n                yaxis: [{\n                    y: 6.2, // A piros vonal pozíciója az y-tengelyen\n                    borderColor: '#FF0000', // Piros vonal színe\n                    strokeDashArray: 0, // Folyamatos vonal (nincs szaggatás)\n                    label: {\n                        style: {\n                            color: '#fff',\n                            background: '#FF0000'\n                        },\n                        text: 'Scrap Product' // A címke a vonal mellett\n                    }\n                }]\n            },\n            dataLabels: {\n                enabled: true,\n                formatter: function(val) {\n                    return val.toFixed(4);\n                },\n                style: {\n                    colors: ['#fff'],\n                    fontSize: '12px'\n                }\n            },\n            plotOptions: {\n                bar: {\n                    distributed: true\n                }\n            },\n            colors: [] // Színek dinamikusan frissítve\n        };\n\n        // Egy 50ms-es késleltetés után rajzolja ki a chartot, így megjelenik gond nélkül\n        setTimeout(() => {\n        const element = document.querySelector(\"#chart\");\n        if (element) {\n        chart = new ApexCharts(element, chartOptions);\n        chart.render();\n        }\n        }, 50);\n\n        // Watch for new messages\n        scope.$watch('msg', function(msg) {\n            if (msg) {\n                if (msg.topic === \"reset\" && Array.isArray(msg.payload) && msg.payload.length === 0) {\n                    chart.updateOptions({\n                        xaxis: { categories: [] },\n                        series: [{ name: \"Adatok\", data: [] }],\n                        colors: []\n                    });\n                } else if (msg.payload !== undefined) {\n                    const timestamp = msg.label || new Date().toLocaleTimeString();\n                    const value = parseFloat(msg.payload);\n                    const color = msg.color_msg || '#0000FF'; // Alapértelmezett kék\n\n                    chart.updateOptions({\n                        xaxis: {\n                            categories: [...chart.w.config.xaxis.categories, timestamp]\n                        },\n                        series: [{\n                            name: \"Adatok\",\n                            data: [...chart.w.config.series[0].data, value]\n                        }],\n                        colors: [...chart.w.config.colors, color]\n                    });\n                }\n            }\n        });\n    })(scope);\n</script>",
